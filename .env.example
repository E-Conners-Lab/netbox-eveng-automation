# Copy this file to `.env` and fill in real values before running docker compose.
# Never commit .env — it is gitignored.

# --- PostgreSQL (NetBox backing store) ---
POSTGRES_DB=netbox
POSTGRES_USER=netbox
POSTGRES_PASSWORD=changeme-postgres-password

# --- Redis ---
REDIS_HOST=redis
REDIS_PORT=6379

# --- NetBox ---
DB_HOST=postgres
DB_NAME=netbox
DB_USER=netbox
DB_PASSWORD=changeme-postgres-password
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=changeme-generate-a-real-secret-key
ALLOWED_HOSTS=localhost,127.0.0.1
SUPERUSER_NAME=admin
SUPERUSER_EMAIL=admin@example.com
SUPERUSER_PASSWORD=changeme-superuser-password
# Generate with: python -c "import secrets; print(secrets.token_hex(20))"
SUPERUSER_API_TOKEN=changeme-generate-a-real-api-token
SKIP_SUPERUSER=false

# --- Orchestrator runtime (read by orchestrator.py / start.sh) ---
NETBOX_URL=http://localhost:8000
NETBOX_TOKEN=changeme-generate-a-real-api-token
EVENG_HOST=192.0.2.10
EVENG_USER=admin
EVENG_PASS=changeme-eveng-password

# Set INSECURE=1 to disable TLS verification (self-signed lab certs).
# Leave unset for real certs. Picked up by start.sh.
# INSECURE=1

# Per-device SSH-reachability timeout in seconds (default 300).
# vIOS ~60-90s, vSRX ~90-180s, vEOS ~60-120s.
# DEVICE_BOOT_TIMEOUT=300
